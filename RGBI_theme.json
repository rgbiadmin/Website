{
  "name": "RGBI - Engineered Governed Proven",
  "dataColors": [
    "#C9A227",
    "#A9B1BC",
    "#1D9E75",
    "#378ADD",
    "#D85A30",
    "#7F77DD",
    "#5F6772",
    "#E0BD52",
    "#0F6E56",
    "#185FA5"
  ],
  "background": "#0A1830",
  "backgroundLight": "#0E1D38",
  "backgroundNeutral": "#1F3354",
  "foreground": "#F4F6F8",
  "foregroundNeutralSecondary": "#A9B1BC",
  "foregroundNeutralTertiary": "#7E8FA6",
  "tableAccent": "#C9A227",
  "good": "#1D9E75",
  "neutral": "#E0BD52",
  "bad": "#D85A30",
  "maximum": "#C9A227",
  "center": "#A9B1BC",
  "minimum": "#0E2240",
  "null": "#5A6B7D",
  "textClasses": {
    "title": {
      "fontFace": "Georgia",
      "fontSize": 14,
      "color": "#F4F6F8"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#D7DCE2"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 24,
      "color": "#D9B654"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#0E1D38" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#1F3354" } },
            "radius": 10
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#070D1A" } }
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#F4F6F8" } },
            "fontFamily": "Georgia",
            "fontSize": 14,
            "bold": true,
            "alignment": "left"
          }
        ],
        "subTitle": [
          {
            "fontColor": { "solid": { "color": "#8FA0B8" } },
            "fontSize": 10
          }
        ],
        "divider": [
          {
            "show": true,
            "color": { "solid": { "color": "#1F3354" } },
            "lineThickness": 1
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#070D1A" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#070D1A" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#D9B654" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#A9B1BC" } },
            "fontSize": 11
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "card": [
          {
            "outlineColor": { "solid": { "color": "#1F3354" } },
            "outlineWeight": 1,
            "backgroundColor": { "solid": { "color": "#0E1D38" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          { "color": { "solid": { "color": "#0E1D38" } } }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#D7DCE2" } },
            "background": { "solid": { "color": "#0E1D38" } }
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#7E8FA6" } },
            "background": { "solid": { "color": "#0E1D38" } },
            "fontSize": 9
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontalColor": { "solid": { "color": "#1F3354" } },
            "rowPadding": 6
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#F4F6F8" } },
            "backColor": { "solid": { "color": "#0A1830" } },
            "fontSize": 10,
            "bold": true
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#D7DCE2" } },
            "backColor": { "solid": { "color": "#0E1D38" } },
            "fontSize": 10
          }
        ],
        "total": [
          {
            "totalsColor": { "solid": { "color": "#D9B654" } },
            "backColor": { "solid": { "color": "#0A1830" } },
            "bold": true
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [
          { "strokeWidth": 3 }
        ],
        "valueAxis": [
          {
            "color": { "solid": { "color": "#A9B1BC" } },
            "gridlineColor": { "solid": { "color": "#1F3354" } },
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "color": { "solid": { "color": "#A9B1BC" } },
            "fontSize": 9
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "valueAxis": [
          {
            "color": { "solid": { "color": "#A9B1BC" } },
            "gridlineColor": { "solid": { "color": "#1F3354" } },
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "color": { "solid": { "color": "#A9B1BC" } },
            "fontSize": 9
          }
        ]
      }
    },
    "kpi": {
      "*": {
        "indicator": [
          { "color": { "solid": { "color": "#D9B654" } } }
        ],
        "goal": [
          { "color": { "solid": { "color": "#A9B1BC" } } }
        ],
        "trendline": [
          { "color": { "solid": { "color": "#C9A227" } } }
        ]
      }
    }
  }
}
